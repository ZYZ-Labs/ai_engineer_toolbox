{
  "name": "ai-engineer-toolbox",
  "main": "./apps/web/functions/worker.ts",
  "compatibility_date": "2026-05-22",
  "assets": {
    "directory": "./apps/web/out",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "toolbox",
      "database_id": "bb58dee2-3ddb-4bd0-95a7-37eacca90923"
    }
  ],
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}
